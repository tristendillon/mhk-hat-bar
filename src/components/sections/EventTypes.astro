---
import { EVENT_TYPES } from "@/lib/constants";
import { Icon } from "@/components/ui/icon";
import {
  Users,
  MapPin,
  PartyPopper,
  Heart,
  Sparkles,
  Building2,
} from "@/icons";

const iconMap = {
  Users,
  MapPin,
  PartyPopper,
  Heart,
  Sparkles,
  Building2,
};
---

<section id="events" class="py-24 bg-purple-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="font-heading text-4xl font-bold text-gray-900 sm:text-5xl">
        Events We Love
      </h2>
      <p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">
        From intimate gatherings to grand celebrations, we bring the hat bar
        experience to any occasion.
      </p>
    </div>

    <!-- Event Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        EVENT_TYPES.map((event) => {
          const IconComponent = iconMap[event.icon as keyof typeof iconMap];
          return (
            <div class="group bg-white rounded-2xl p-8 shadow-md border border-purple-100 transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
              <div class="flex flex-col items-center text-center">
                <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-purple-100 text-purple-600 transition-colors group-hover:bg-purple-600 group-hover:text-white">
                  <Icon src={IconComponent} size={32} />
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-3">
                  {event.title}
                </h3>
                <p class="text-gray-500 leading-relaxed">{event.description}</p>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
