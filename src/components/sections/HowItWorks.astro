---
import { PROCESS_STEPS } from "@/lib/constants";
---

<section id="how-it-works" class="py-24 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="font-heading text-4xl font-bold text-gray-900 sm:text-5xl">
        How It Works
      </h2>
      <p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">
        Creating your custom hat is simple, fun, and unforgettable.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative">
      <!-- Connecting Line (Desktop) -->
      <div
        class="hidden lg:block absolute top-1/2 left-0 right-0 h-0.5 bg-purple-200 -translate-y-1/2"
      >
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-8">
        {
          PROCESS_STEPS.map((step, index) => (
            <div class="relative flex flex-col items-center text-center">
              {/* Step Number */}
              <div class="relative z-10 flex h-16 w-16 items-center justify-center rounded-full bg-purple-600 text-white text-2xl font-bold shadow-lg mb-6">
                {step.step}
              </div>

              {/* Content */}
              <h3 class="text-xl font-semibold text-gray-900 mb-3">
                {step.title}
              </h3>
              <p class="text-gray-500 max-w-xs">{step.description}</p>

              {/* Mobile Connector */}
              {index < PROCESS_STEPS.length - 1 && (
                <div class="lg:hidden w-0.5 h-12 bg-purple-200 mt-6" />
              )}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
